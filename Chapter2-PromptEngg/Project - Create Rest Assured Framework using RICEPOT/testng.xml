<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RestfulBookerSuite" parallel="tests" thread-count="4">
  <test name="SmokeTests">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <classes>
      <class name="com.bookerframework.tests.AuthTests"/>
      <class name="com.bookerframework.tests.BookingTests"/>
    </classes>
  </test>
  <test name="RegressionTests">
    <groups>
      <run>
        <include name="regression"/>
      </run>
    </groups>
    <classes>
      <class name="com.bookerframework.tests.AuthTests"/>
      <class name="com.bookerframework.tests.BookingTests"/>
    </classes>
  </test>
  <test name="NegativeTests">
    <groups>
      <run>
        <include name="negative"/>
      </run>
    </groups>
    <classes>
      <class name="com.bookerframework.tests.AuthTests"/>
      <class name="com.bookerframework.tests.BookingTests"/>
    </classes>
  </test>
</suite>
